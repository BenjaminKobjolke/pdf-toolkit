{
  "log_level": "all",
  "max_lines_per_file": {
    "enabled": true,
    "warning": 300,
    "error": 500
  },
  "pmd_duplicates": {
    "enabled": true,
    "minimum_tokens": 100,
    "exclude_patterns": {
      "python": [
        "__pycache__/**",
        "*.pyc",
        "venv/**",
        ".venv/**",
        "*venv/**",
        "env/**",
        ".git/**"
      ]
    }
  },
  "pmd_similar_code": {
    "enabled": false,
    "minimum_tokens": 100,
    "ignore_identifiers": true,
    "ignore_literals": true,
    "ignore_annotations": false,
    "exclude_patterns": {
      "python": [
        "__pycache__/**",
        "*.pyc",
        "venv/**",
        ".venv/**",
        "*venv/**",
        "env/**",
        ".git/**"
      ]
    }
  },
  "ruff_analyze": {
    "enabled": true,
    "select": ["E", "F", "W", "I", "UP", "B", "SIM"],
    "ignore": [],
    "exclude_patterns": ["venv/**", ".venv/**", "__pycache__/**", ".git/**"]
  }
}
