# Normalize all text files to LF in the repository
* text=auto eol=lf

# Windows batch files must be CRLF for cmd.exe compatibility
*.bat text eol=crlf
*.cmd text eol=crlf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
